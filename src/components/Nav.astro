---
import { siteConfig } from "../config";

const navLinks = [
  { href: "#sobre-mi", label: "Sobre Mí" },
  { href: "#expertise", label: "Expertise" },
  { href: "#trayectoria", label: "Trayectoria" },
  { href: "#formacion", label: "Formación" },
  { href: "#contacto", label: "Contacto" },
];

const initials = siteConfig.name
  .split(" ")
  .filter((_, i) => i === 0 || i === 2)
  .map((w) => w[0])
  .join("");
---

<nav
  id="floating-nav"
  class="fixed top-4 left-1/2 -translate-x-1/2 z-50 opacity-0 pointer-events-none transition-all duration-300"
  aria-label="Navegación principal"
>
  <div
    class="flex items-center gap-1 px-2 py-2 rounded-full shadow-lg border border-gray-200/60"
    style="background: rgba(255,255,255,0.82); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
  >
    <!-- Initials logo -->
    <a
      href="#"
      class="flex items-center justify-center w-9 h-9 rounded-full text-sm font-bold text-white shrink-0"
      style={`background-color: var(--color-primary);`}
      aria-label="Inicio"
    >
      {initials}
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="px-3 py-1.5 text-sm font-medium rounded-full transition-colors duration-200 hover:bg-gray-100"
            style="color: var(--color-primary-dark);"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden flex items-center justify-center w-9 h-9 rounded-full hover:bg-gray-100 transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg id="hamburger-icon" class="w-5 h-5" style="color: var(--color-primary-dark);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-5 h-5 hidden" style="color: var(--color-primary-dark);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="hidden md:hidden mt-2 rounded-2xl shadow-lg border border-gray-200/60 overflow-hidden"
    style="background: rgba(255,255,255,0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
  >
    <ul class="flex flex-col py-2">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link block px-5 py-3 text-sm font-medium transition-colors duration-200 hover:bg-gray-100"
            style="color: var(--color-primary-dark);"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const nav = document.getElementById("floating-nav") as HTMLElement;
  const toggle = document.getElementById("nav-toggle") as HTMLButtonElement;
  const menu = document.getElementById("mobile-menu") as HTMLElement;
  const hamburger = document.getElementById("hamburger-icon") as HTMLElement;
  const closeIcon = document.getElementById("close-icon") as HTMLElement;

  // Show/hide nav on scroll
  let lastScroll = 0;
  const showThreshold = 400;

  function updateNav() {
    const y = window.scrollY;
    if (y > showThreshold) {
      nav.classList.remove("opacity-0", "pointer-events-none");
      nav.classList.add("opacity-100", "pointer-events-auto", "header-visible");
    } else {
      nav.classList.add("opacity-0", "pointer-events-none");
      nav.classList.remove("opacity-100", "pointer-events-auto", "header-visible");
      // Close mobile menu when scrolling back to top
      menu.classList.add("hidden");
      hamburger.classList.remove("hidden");
      closeIcon.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
    }
    lastScroll = y;
  }

  window.addEventListener("scroll", updateNav, { passive: true });

  // Mobile toggle
  toggle.addEventListener("click", () => {
    const isOpen = !menu.classList.contains("hidden");
    menu.classList.toggle("hidden");
    hamburger.classList.toggle("hidden");
    closeIcon.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      hamburger.classList.remove("hidden");
      closeIcon.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
    });
  });
</script>
