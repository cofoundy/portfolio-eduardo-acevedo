---
import { siteConfig } from "../config";

const contactCards = [
  {
    label: "Email",
    value: siteConfig.social.email,
    href: `mailto:${siteConfig.social.email}`,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
  {
    label: "LinkedIn",
    value: "Eduardo Acevedo",
    href: siteConfig.social.linkedin,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />`,
  },
  {
    label: "WhatsApp",
    value: `+${siteConfig.social.whatsapp}`,
    href: `https://wa.me/${siteConfig.social.whatsapp}`,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />`,
  },
];

const currentYear = new Date().getFullYear();
---

<footer id="contacto" style="background-color: var(--color-primary-dark);">
  <!-- Contact section -->
  <div class="py-16 sm:py-20 lg:py-24">
    <div class="max-w-5xl mx-auto px-5">
      <!-- Header -->
      <div class="text-center mb-12 reveal">
        <span
          class="inline-block text-xs font-semibold tracking-widest uppercase mb-3"
          style="color: var(--color-accent);"
        >
          Hablemos
        </span>
        <h2
          class="text-3xl sm:text-4xl font-bold text-white"
          style="font-family: 'DM Serif Display', serif;"
        >
          Contacto
        </h2>
        <div class="w-16 h-1 mt-4 mx-auto rounded-full" style="background-color: var(--color-accent);"></div>
        <p class="mt-5 text-gray-400 text-base max-w-md mx-auto">
          Si estás buscando un profesional con visión integral de operaciones, hablemos.
        </p>
      </div>

      <!-- Contact cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
        {contactCards.map((card, i) => (
          <a
            href={card.href}
            target={card.label !== "Email" ? "_blank" : undefined}
            rel={card.label !== "Email" ? "noopener noreferrer" : undefined}
            class={`reveal-scale stagger-${i + 1} group block rounded-2xl p-6 text-center transition-all duration-300 border border-white/10 hover:border-white/25`}
            style="background: rgba(255,255,255,0.05);"
          >
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4 transition-transform duration-300 group-hover:scale-110"
              style={`background-color: var(--color-accent);`}
            >
              <svg
                class="w-5 h-5"
                style={`color: var(--color-primary-dark);`}
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <Fragment set:html={card.icon} />
              </svg>
            </div>
            <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">{card.label}</p>
            <p class="text-sm text-white font-medium break-all">{card.value}</p>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-5xl mx-auto px-5 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-gray-500">
        &copy; {currentYear} {siteConfig.name}. Todos los derechos reservados.
      </p>
      <p class="text-xs text-gray-500">
        Hecho con <span class="text-red-400">&hearts;</span> por
        <a
          href="https://cofoundy.dev"
          target="_blank"
          rel="noopener noreferrer"
          class="link-underline font-medium text-gray-400 hover:text-white transition-colors"
        >
          Cofoundy
        </a>
      </p>
    </div>
  </div>
</footer>
