---
import { siteConfig } from "../config";

const iconSvgs: Record<string, string> = {
  operations: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  "supply-chain": `<path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />`,
  compliance: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  team: `<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />`,
};
---

<section id="expertise" class="py-16 sm:py-20 lg:py-24" style="background-color: var(--color-surface);">
  <div class="max-w-6xl mx-auto px-5">
    <!-- Section header -->
    <div class="text-center mb-12 reveal">
      <span
        class="inline-block text-xs font-semibold tracking-widest uppercase mb-3"
        style="color: var(--color-accent);"
      >
        Competencias Clave
      </span>
      <h2
        class="text-3xl sm:text-4xl font-bold"
        style={`color: var(--color-primary-dark); font-family: 'DM Serif Display', serif;`}
      >
        Expertise
      </h2>
      <div class="w-16 h-1 mt-4 mx-auto rounded-full" style="background-color: var(--color-accent);"></div>
    </div>

    <!-- 2x2 Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {siteConfig.expertise.map((item, i) => (
        <div
          class={`card-hover reveal-scale stagger-${i + 1} bg-white rounded-2xl p-6 sm:p-8 shadow-sm border border-gray-100`}
        >
          <!-- Icon -->
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center mb-5"
            style={`background-color: var(--color-primary-dark);`}
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <Fragment set:html={iconSvgs[item.icon] || iconSvgs.operations} />
            </svg>
          </div>

          <!-- Title -->
          <h3
            class="text-xl font-bold mb-3"
            style={`color: var(--color-primary-dark); font-family: 'DM Serif Display', serif;`}
          >
            {item.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-600 text-sm leading-relaxed mb-5">
            {item.description}
          </p>

          <!-- Keywords pills -->
          <div class="flex flex-wrap gap-2">
            {item.keywords.map((kw) => (
              <span
                class="inline-block text-xs font-medium px-3 py-1 rounded-full"
                style={`background-color: var(--color-surface); color: var(--color-primary);`}
              >
                {kw}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
