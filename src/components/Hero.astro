---
import { siteConfig } from "../config";
---

<section class="relative overflow-hidden" style="background-color: var(--color-surface-light);">
  <!-- Subtle background accent -->
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-[0.03]" style={`background: radial-gradient(ellipse at 80% 20%, var(--color-primary), transparent 70%);`}></div>

  <div class="relative max-w-6xl mx-auto px-5 py-16 sm:py-20 lg:py-28">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">

      <!-- Left: Photo -->
      <div class="hero-photo flex-shrink-0">
        <div
          class="relative w-44 h-44 sm:w-52 sm:h-52 rounded-2xl p-1"
          style={`background: linear-gradient(135deg, var(--color-primary), var(--color-accent));`}
        >
          <div
            class="w-full h-full rounded-xl flex items-center justify-center overflow-hidden"
            style="background-color: var(--color-surface);"
          >
            <img
              src="/profile.png"
              alt={siteConfig.name}
              class="w-full h-full object-cover"
              width="208"
              height="208"
            />
          </div>
          <!-- Decorative dot -->
          <div
            class="absolute -bottom-2 -right-2 w-6 h-6 rounded-full"
            style="background-color: var(--color-accent);"
          ></div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="flex-1 text-center lg:text-left">
        <!-- Name -->
        <h1
          class="hero-title text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight"
          style={`color: var(--color-primary-dark); font-family: 'DM Serif Display', serif;`}
        >
          {siteConfig.name}
        </h1>

        <!-- Title -->
        <p
          class="hero-subtitle mt-3 text-lg sm:text-xl font-semibold"
          style="color: var(--color-primary);"
        >
          {siteConfig.title}
        </p>

        <!-- Tagline -->
        <p
          class="hero-description mt-4 text-base sm:text-lg leading-relaxed max-w-xl mx-auto lg:mx-0"
          style="color: var(--color-primary-light);"
        >
          {siteConfig.tagline}
        </p>

        <!-- CTA buttons -->
        <div class="hero-cta mt-6 flex flex-wrap gap-3 justify-center lg:justify-start">
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="btn-hover inline-flex items-center gap-2 px-6 py-3 rounded-full text-white text-sm font-semibold shadow-lg"
            style={`background-color: var(--color-accent);`}
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Email
          </a>
          <a
            href={`https://wa.me/${siteConfig.social.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-hover inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-semibold shadow-lg border-2"
            style={`color: var(--color-primary-dark); border-color: var(--color-primary); background-color: white;`}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>

        <!-- Stats -->
        <div class="hero-stats mt-10 grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 max-w-lg mx-auto lg:mx-0">
          {siteConfig.stats.map((stat) => (
            <div class="text-center lg:text-left">
              <span
                class="block text-2xl sm:text-3xl font-bold font-mono"
                style={`color: var(--color-accent); font-family: 'JetBrains Mono', monospace;`}
              >
                {stat.value}
              </span>
              <span class="block mt-1 text-xs sm:text-sm text-gray-500">
                {stat.label}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom shimmer separator -->
  <div class="bar-shimmer h-1 w-full"></div>
</section>
