---
import { siteConfig } from "../config";
---

<section class="relative overflow-hidden" style="background-color: var(--color-surface-light);">
  <!-- Subtle background accent -->
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-[0.03]" style={`background: radial-gradient(ellipse at 80% 20%, var(--color-primary), transparent 70%);`}></div>

  <div class="relative max-w-6xl mx-auto px-5 py-16 sm:py-20 lg:py-28">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">

      <!-- Left: Photo -->
      <div class="hero-photo flex-shrink-0">
        <div
          class="relative w-44 h-44 sm:w-52 sm:h-52 rounded-2xl p-1"
          style={`background: linear-gradient(135deg, var(--color-primary), var(--color-accent));`}
        >
          <div
            class="w-full h-full rounded-xl flex items-center justify-center overflow-hidden"
            style="background-color: var(--color-surface);"
          >
            <img
              src="/profile.png"
              alt={siteConfig.name}
              class="w-full h-full object-cover"
              width="208"
              height="208"
            />
          </div>
          <!-- Decorative dot -->
          <div
            class="absolute -bottom-2 -right-2 w-6 h-6 rounded-full"
            style="background-color: var(--color-accent);"
          ></div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="flex-1 text-center lg:text-left">
        <!-- Name -->
        <h1
          class="hero-title text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight"
          style={`color: var(--color-primary-dark); font-family: 'DM Serif Display', serif;`}
        >
          {siteConfig.name}
        </h1>

        <!-- Title -->
        <p
          class="hero-subtitle mt-3 text-lg sm:text-xl font-semibold"
          style="color: var(--color-primary);"
        >
          {siteConfig.title}
        </p>

        <!-- Tagline -->
        <p
          class="hero-description mt-4 text-base sm:text-lg leading-relaxed max-w-xl mx-auto lg:mx-0"
          style="color: var(--color-primary-light);"
        >
          {siteConfig.tagline}
        </p>

        <!-- CTA button -->
        <div class="hero-cta mt-6">
          <a
            href="#contacto"
            class="btn-hover inline-flex items-center gap-2 px-6 py-3 rounded-full text-white text-sm font-semibold shadow-lg"
            style={`background-color: var(--color-accent);`}
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Contactar
          </a>
        </div>

        <!-- Stats -->
        <div class="hero-stats mt-10 grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 max-w-lg mx-auto lg:mx-0">
          {siteConfig.stats.map((stat) => (
            <div class="text-center lg:text-left">
              <span
                class="block text-2xl sm:text-3xl font-bold font-mono"
                style={`color: var(--color-accent); font-family: 'JetBrains Mono', monospace;`}
              >
                {stat.value}
              </span>
              <span class="block mt-1 text-xs sm:text-sm text-gray-500">
                {stat.label}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom shimmer separator -->
  <div class="bar-shimmer h-1 w-full"></div>
</section>
