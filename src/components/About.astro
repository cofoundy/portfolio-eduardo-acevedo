---
import { siteConfig } from "../config";
---

<section id="sobre-mi" class="bg-white py-16 sm:py-20 lg:py-24">
  <div class="max-w-6xl mx-auto px-5">
    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16 items-start">

      <!-- Left: Heading + Text -->
      <div class="flex-1 reveal-left">
        <span
          class="inline-block text-xs font-semibold tracking-widest uppercase mb-3"
          style="color: var(--color-accent);"
        >
          Perfil Profesional
        </span>
        <h2
          class="text-3xl sm:text-4xl font-bold"
          style={`color: var(--color-primary-dark); font-family: 'DM Serif Display', serif;`}
        >
          Sobre Mí
        </h2>
        <div class="w-16 h-1 mt-4 mb-6 rounded-full" style="background-color: var(--color-accent);"></div>
        <p class="text-base sm:text-lg leading-relaxed text-gray-600">
          {siteConfig.aboutMe}
        </p>
      </div>

      <!-- Right: Floating quote card -->
      <div class="w-full lg:w-80 flex-shrink-0 reveal-right stagger-2">
        <div
          class="quote-float relative p-6 rounded-2xl border-l-4 shadow-md"
          style={`border-color: var(--color-accent); background-color: var(--color-surface-light);`}
        >
          <!-- Quote icon -->
          <svg
            class="w-8 h-8 mb-3 opacity-20"
            style="color: var(--color-accent);"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
          </svg>
          <p
            class="text-base italic leading-relaxed"
            style="color: var(--color-primary-dark);"
          >
            "{siteConfig.quote.text}"
          </p>
          <p
            class="mt-4 text-sm font-semibold"
            style="color: var(--color-primary);"
          >
            — {siteConfig.quote.author}
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
